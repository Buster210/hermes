# ============================================================================
# Hermes WebUI — merged HF Spaces / local deployment
# ============================================================================

# ── Required ──
GATEWAY_TOKEN=change-me-to-a-strong-random-string
LLM_API_KEY=your-llm-provider-api-key
LLM_MODEL=openrouter/anthropic/claude-sonnet-4

# ── Hosting URL (auto-detected on HuggingFace Spaces, set manually for self-hosted) ──
# SPACE=https://your-username-space-name.hf.space
# SPACE=http://localhost:7861  # for local dev

# ── Provider API keys ──
# Set only the keys you use. AI-provider domains (api.openai.com, api.anthropic.com, etc.)
# are NOT proxied by default. To proxy AI API calls, add the domains to CLOUDFLARE_PROXY_DOMAINS.
# Single key:
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...
# GEMINI_API_KEY=AIza...
# OPENROUTER_API_KEY=sk-or-...
# OLLAMA_API_KEY=
# DEEPSEEK_API_KEY=...
# XAI_API_KEY=...
# HERMES_INFERENCE_PROVIDER=auto
#
# ── Key pools (round-robin rotation) ──
# Supply multiple keys for a provider via its *_API_KEYS var to register a
# credential pool that Hermes rotates round-robin. Accepts comma-separated OR a
# JSON array. A pool supersedes the matching singular key. Survives restarts
# (added once, skipped on reboot; only new/changed keys are re-synced).
#   OPENROUTER_API_KEYS=sk-or-key1, sk-or-key2, sk-or-key3
#   GEMINI_API_KEYS=["AIza-key1","AIza-key2"]
# Supported pool vars: GEMINI_API_KEYS, OPENROUTER_API_KEYS, ANTHROPIC_API_KEYS,
# OPENAI_API_KEYS, DEEPSEEK_API_KEYS, XAI_API_KEYS, KIMI_API_KEYS, MINIMAX_API_KEYS,
# NVIDIA_API_KEYS, KILOCODE_API_KEYS, GLM_API_KEYS, ARCEEAI_API_KEYS,
# DASHSCOPE_API_KEYS, GMI_API_KEYS, TOKENHUB_API_KEYS, OLLAMA_API_KEYS.

# ── Custom OpenAI-compatible endpoint ──
# CUSTOM_BASE_URL=http://localhost:11434/v1
# CUSTOM_API_KEY=
# CUSTOM_PROVIDER=custom
# CUSTOM_MODEL_CONTEXT_LENGTH=131072
# CUSTOM_MODEL_MAX_TOKENS=8192

# ── WebUI (landing experience) ──
# PRIMARY_UI=webui
# HERMES_WEBUI_PORT=8787
# HERMES_WEBUI_PASSWORD=
# HERMES_WEBUI_STATE_DIR=/opt/data/webui
# HERMES_WEBUI_DEFAULT_WORKSPACE=/opt/data/workspace

# ── HF Storage Bucket persistence ──
# State backs up to a private HF Storage Bucket. Every agent shares ONE bucket and
# writes under its own AGENT_NAME prefix, so multiple agents never clobber each other.
# BACKUP_BUCKET_NAME=hermes-backup       # shared bucket name (default hermes-backup)
# AGENT_NAME=primary                     # per-agent prefix + state dir (lowercased; default primary)
# MIGRATE_FROM_DATASET=true              # one-time legacy dataset->bucket import when prefix is empty
# BACKUP_DATASET_NAME=hermes-backup      # legacy dataset, used only as the migration source
# SYNC_POLL_INTERVAL=2
# SYNC_DEBOUNCE_SECONDS=3
# SYNC_INTERVAL=60
# SYNC_INCLUDE_ENV=1

# ── Telegram bridge ──
# TELEGRAM_BOT_TOKEN=123456:ABC
# TELEGRAM_ALLOWED_USERS=11111111,22222222
# TELEGRAM_MODE=webhook
# TELEGRAM_WEBHOOK_URL=https://your-space.hf.space/telegram
# Set TELEGRAM_MODE=polling to long-poll instead of webhook. On HF/Render this
# REQUIRES a Telegram proxy (CLOUDFLARE_PROXY_URL or TELEGRAM_BASE_URL) since
# outbound api.telegram.org is blocked there.
# On every container (re)start, once the stack is up, a customised "online"
# greeting is sent once to the Telegram home channel via the hermes-online hook
# (LLM-personalised, with a deterministic time-of-day fallback).
# Requires TELEGRAM_BOT_TOKEN + TELEGRAM_HOME_CHANNEL.
TELEGRAM_BOOT_TZ=Asia/Kolkata  # optional tz for the greeting (else TZ, else server time)

# ── Cloudflare proxy + keep-alive ──
# CLOUDFLARE_WORKERS_TOKEN=cf_xxx
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_KEEPALIVE_CRON=*/10 * * * *
# CLOUDFLARE_PROXY_DOMAINS=api.sendgrid.com,slack.com
#   AI-provider domains are NOT proxied by default. Add api.openai.com to opt-in.
# CLOUDFLARE_PROXY_URL=https://your-worker.your-subdomain.workers.dev
# CLOUDFLARE_PROXY_SECRET=your-proxy-secret

# ── Private Space detection (HF Spaces only) ──
# SPACE_ID=your-org/your-space  # Auto-detected on HF Spaces
# SPACE_HOST=your-space.hf.space  # Auto-detected
# SPACE_PRIVACY=public  # Override privacy detection: "public" or "private"
# HF_TOKEN=your-hf-token  # Used for space privacy API detection

# ── Supervisor / notifications ──
# SUPERVISOR_MAX_RESTARTS=0
# SUPERVISOR_POLL_INTERVAL=5
# WEBHOOK_URL=https://your-webhook-endpoint.com/notify

# ── Boot-time package installs (opt-in; run on every container start) ──
# System packages (ffmpeg, poppler-utils) are in the Dockerfile at build time.
# Space-separated lists, installed best-effort on boot (failures logged, not fatal).
# HERMES_PIP_PACKAGES=httpx rich
# HERMES_NPM_PACKAGES=prettier
# Arbitrary boot script — inline shell, or a base64:/b64: prefixed payload.
# HERMES_RUN=echo "ready"

# ── Shell capture (HF Spaces terminal installs) ──
# HERMES_CAPTURE_DISABLE=1  # Disable capture of terminal pip/npm installs

# ── Pin Hermes Agent base image ──
# HERMES_AGENT_VERSION=latest