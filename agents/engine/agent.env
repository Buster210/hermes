# Per-agent NON-secret overrides for the "engine" agent.
# Secrets (tokens, API keys) live in the repo-root .env or platform secrets — never here.
# Loaded after root .env, so these win for this agent.

AGENT_PERSONALITY=kawaii

# Fixed host port for local `docker compose` (container always listens on 7860).
# Each agent gets a unique one so several can run at once. Registry in README.md.
HOST_PORT=7861

# Telegram API base URL (Cloudflare Worker proxy; HF blocks api.telegram.org directly).
# Leave unset to use the committed default in .hermes/config.yaml.
TELEGRAM_BASE_URL=https://hermes.22f2001388.workers.dev/bot
